# copy to .env
BROKER=fake                # switch to robinhood only after shadow mode passes
TRADING_MODE=sim           # sim | shadow | read_only | live
RUNTIME_TOKEN=             # required outside sim; agent-runtime write grant
ADMIN_TOKEN=               # required outside sim; review/halt grant
KERNEL_TOKEN=              # required outside sim; kernel -> runtime /wake
LIVE_TRADING_ENABLED=false # must be exactly true before live can start
LIVE_ACCOUNT_ID=           # exact provider account id; required in live
COGNITION=stub             # switch to llm after prompt slots are filled
DECIDER_MODEL=             # expensive model for desk_master / coach
MONITOR_MODEL=             # cheap model for scout / position_manager
# robinhood adapter (unused while BROKER=fake)
ROBINHOOD_USERNAME=
ROBINHOOD_PASSWORD=
