# copy to .env
BROKER=fake                # switch to robinhood only after shadow mode passes
TRADING_MODE=sim           # sim | shadow | read_only | live
RUNTIME_TOKEN=             # required outside sim; agent-runtime write grant
ADMIN_TOKEN=               # required outside sim; review/halt grant
KERNEL_TOKEN=              # required outside sim; kernel -> runtime /wake
RUNTIME_URL=http://agent-runtime:8200 # internal kernel -> runtime wake endpoint
TICK_SECONDS=300           # runtime fallback cadence; 0 = watchdog spine only
CONSOLE_ORIGIN=http://localhost:8100 # exact browser origin allowed to mutate controls
LIVE_TRADING_ENABLED=false # must be exactly true before live can start
LIVE_ACCOUNT_ID=           # exact provider account id; required for all Robinhood modes
LIVE_ACCOUNT_ID_FILE=      # preferred 0600 binding file; do not set together with LIVE_ACCOUNT_ID
RH_MCP_TOKEN_FILE=         # absolute 0600 OAuth path when running kernel directly
RH_MCP_SECRET_DIR=         # host OAuth directory for docker-compose.robinhood.yml
RH_MCP_CAPABILITIES_FILE=  # committed docs/rh_mcp_capabilities.json path
DB_TIMEOUT_MS=3000         # deadline for every database call
BROKER_TIMEOUT_MS=10000    # bound each broker call
CLAIM_TIMEOUT_MS=30000     # must exceed BROKER_TIMEOUT_MS
ATTEMPT_STALE_MS=3000      # pending-attempt recovery threshold
COGNITION=stub             # switch to llm after prompt slots are filled
DECIDER_MODEL=             # expensive model for desk_master / coach
MONITOR_MODEL=             # cheap model for scout / position_manager
ANTHROPIC_API_KEY=         # required at startup when COGNITION=llm
AGENT_WEB_PASSWORD=        # optional 12+ byte password for /agent-lab
AGENT_WEB_SESSION_KEY=     # optional 32+ byte random cookie-signing key
SESSION_TOKEN_BUDGET=12000 # exact total input-token ceiling; never truncated
PROMPT_SLOT_MAX_BYTES=8192 # hard cap for each authored prompt slot
CONTEXT_SLOT_MAX_BYTES=1048576 # hard cap for each assembled JSON context slot
# robinhood adapter (unused while BROKER=fake)
ROBINHOOD_USERNAME=
ROBINHOOD_PASSWORD=
