{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://alpheus.local/contracts/runtime/v1/schema/runtime.schema.json",
  "title": "Alpheus AP1 Durable Runtime Contracts v1",
  "oneOf": [
    {"$ref": "#/$defs/RuntimePolicy"},
    {"$ref": "#/$defs/TriggerRegistration"},
    {"$ref": "#/$defs/TriggerOccurrence"},
    {"$ref": "#/$defs/Run"},
    {"$ref": "#/$defs/Task"},
    {"$ref": "#/$defs/Dependency"},
    {"$ref": "#/$defs/Session"},
    {"$ref": "#/$defs/Attempt"},
    {"$ref": "#/$defs/Turn"},
    {"$ref": "#/$defs/ModelCallManifest"},
    {"$ref": "#/$defs/ModelCallResult"},
    {"$ref": "#/$defs/Artifact"},
    {"$ref": "#/$defs/ArtifactPublicationIntent"},
    {"$ref": "#/$defs/Checkpoint"},
    {"$ref": "#/$defs/BudgetLedger"},
    {"$ref": "#/$defs/CancellationRequest"},
    {"$ref": "#/$defs/RecoveryRecord"},
    {"$ref": "#/$defs/RuntimeEvent"},
    {"$ref": "#/$defs/ClaimTaskCommand"},
    {"$ref": "#/$defs/HeartbeatAttemptCommand"},
    {"$ref": "#/$defs/CommitAttemptCommand"},
    {"$ref": "#/$defs/RequestChildTaskCommand"}
  ],
  "$defs": {
    "Identifier": {"type": "string", "minLength": 1, "maxLength": 200, "pattern": "^[^\\u0000-\\u0020\\u007f]+$"},
    "Name": {"type": "string", "pattern": "^[a-z][a-z0-9_]{0,63}$"},
    "Digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "Timestamp": {"type": "string", "format": "date-time", "pattern": "Z$"},
    "AuditActor": {"$ref": "https://alpheus.local/contracts/common/v1/schema/common.schema.json#/$defs/AuditActor"},
    "RecordRef": {"$ref": "https://alpheus.local/contracts/common/v1/schema/common.schema.json#/$defs/RecordRef"},
    "RevisionRef": {"$ref": "https://alpheus.local/contracts/common/v1/schema/common.schema.json#/$defs/RevisionRef"},
    "RunOrigin": {"$ref": "https://alpheus.local/contracts/common/v1/schema/common.schema.json#/$defs/RunOrigin"},
    "CommandEnvelope": {"$ref": "https://alpheus.local/contracts/common/v1/schema/common.schema.json#/$defs/CommandEnvelope"},
    "Failure": {"$ref": "https://alpheus.local/contracts/common/v1/schema/common.schema.json#/$defs/Failure"},
    "BlobRef": {"$ref": "https://alpheus.local/contracts/blob/v1/blob.schema.json#/$defs/BlobRef"},
    "BudgetLimit": {
      "type": "object", "additionalProperties": false,
      "required": ["max_model_calls", "max_input_tokens", "max_output_tokens", "max_tool_calls", "max_external_cost_micro_usd", "max_wall_time_ms", "max_idle_time_ms", "max_tasks", "max_depth", "max_fanout", "max_parallelism", "max_invalid_output_retries", "max_infrastructure_retries"],
      "properties": {
        "max_model_calls": {"type": "integer", "minimum": 0},
        "max_input_tokens": {"type": "integer", "minimum": 0},
        "max_output_tokens": {"type": "integer", "minimum": 0},
        "max_tool_calls": {"type": "integer", "minimum": 0},
        "max_external_cost_micro_usd": {"type": "integer", "minimum": 0},
        "max_wall_time_ms": {"type": "integer", "minimum": 0},
        "max_idle_time_ms": {"type": "integer", "minimum": 0},
        "max_tasks": {"type": "integer", "minimum": 0},
        "max_depth": {"type": "integer", "minimum": 0},
        "max_fanout": {"type": "integer", "minimum": 0},
        "max_parallelism": {"type": "integer", "minimum": 0},
        "max_invalid_output_retries": {"type": "integer", "minimum": 0},
        "max_infrastructure_retries": {"type": "integer", "minimum": 0}
      }
    },
    "BudgetUsage": {
      "type": "object", "additionalProperties": false,
      "required": ["model_calls", "input_tokens", "output_tokens", "tool_calls", "external_cost_micro_usd", "wall_time_ms", "tasks", "active_tasks", "invalid_output_retries", "infrastructure_retries"],
      "properties": {
        "model_calls": {"type": "integer", "minimum": 0},
        "input_tokens": {"type": "integer", "minimum": 0},
        "output_tokens": {"type": "integer", "minimum": 0},
        "tool_calls": {"type": "integer", "minimum": 0},
        "external_cost_micro_usd": {"type": "integer", "minimum": 0},
        "wall_time_ms": {"type": "integer", "minimum": 0},
        "tasks": {"type": "integer", "minimum": 0},
        "active_tasks": {"type": "integer", "minimum": 0},
        "invalid_output_retries": {"type": "integer", "minimum": 0},
        "infrastructure_retries": {"type": "integer", "minimum": 0}
      }
    },
    "AttemptLease": {
      "type": "object", "additionalProperties": false,
      "required": ["generation", "token", "worker", "claimed_at", "heartbeat_at", "expires_at"],
      "properties": {
        "generation": {"type": "integer", "minimum": 1},
        "token": {"$ref": "#/$defs/Identifier"},
        "worker": {"$ref": "#/$defs/AuditActor"},
        "claimed_at": {"$ref": "#/$defs/Timestamp"},
        "heartbeat_at": {"$ref": "#/$defs/Timestamp"},
        "expires_at": {"$ref": "#/$defs/Timestamp"}
      }
    },
    "ArtifactSection": {
      "type": "object", "additionalProperties": false,
      "required": ["name", "required", "content"],
      "properties": {
        "name": {"$ref": "#/$defs/Name"},
        "required": {"type": "boolean"},
        "content": {"$ref": "#/$defs/BlobRef"}
      }
    },
    "RuntimePolicy": {
      "type": "object", "additionalProperties": false,
      "required": ["schema_revision", "policy_id", "generation", "default_run_limit", "max_lease_seconds", "max_heartbeat_extension_seconds", "max_claim_batch", "max_dependencies", "max_artifact_sections", "dead_letter_retention_seconds", "updated_by", "updated_at"],
      "properties": {
        "schema_revision": {"const": 1},
        "policy_id": {"$ref": "#/$defs/Identifier"},
        "generation": {"type": "integer", "minimum": 1},
        "default_run_limit": {"$ref": "#/$defs/BudgetLimit"},
        "max_lease_seconds": {"type": "integer", "minimum": 1},
        "max_heartbeat_extension_seconds": {"type": "integer", "minimum": 1},
        "max_claim_batch": {"type": "integer", "minimum": 1},
        "max_dependencies": {"type": "integer", "minimum": 1, "maximum": 4096},
        "max_artifact_sections": {"type": "integer", "minimum": 1, "maximum": 256},
        "dead_letter_retention_seconds": {"type": "integer", "minimum": 1},
        "updated_by": {"$ref": "#/$defs/AuditActor"},
        "updated_at": {"$ref": "#/$defs/Timestamp"}
      }
    },
    "TriggerRegistration": {
      "type": "object", "additionalProperties": false,
      "required": ["schema_revision", "registration_id", "generation", "kind", "source_key", "owner_policy", "runtime_policy", "enabled", "updated_by", "updated_at"],
      "properties": {
        "schema_revision": {"const": 1},
        "registration_id": {"$ref": "#/$defs/Identifier"},
        "generation": {"type": "integer", "minimum": 1},
        "kind": {"enum": ["schedule", "kernel_event", "external_event", "system_maintenance"]},
        "source_key": {"$ref": "#/$defs/Identifier"},
        "owner_policy": {"$ref": "#/$defs/RevisionRef"},
        "runtime_policy": {"$ref": "#/$defs/RevisionRef"},
        "enabled": {"type": "boolean"},
        "updated_by": {"$ref": "#/$defs/AuditActor"},
        "updated_at": {"$ref": "#/$defs/Timestamp"}
      }
    },
    "TriggerOccurrence": {
      "type": "object", "additionalProperties": false,
      "required": ["schema_revision", "occurrence_id", "registration", "kind", "source", "initiating_actor", "owner_policy", "occurrence_key", "occurred_at", "observed_at", "committed_at"],
      "properties": {
        "schema_revision": {"const": 1},
        "occurrence_id": {"$ref": "#/$defs/Identifier"},
        "registration": {"$ref": "#/$defs/RevisionRef"},
        "kind": {"enum": ["schedule", "kernel_event", "external_event", "system_maintenance"]},
        "source": {"$ref": "#/$defs/RecordRef"},
        "initiating_actor": {"$ref": "#/$defs/AuditActor"},
        "owner_policy": {"$ref": "#/$defs/RevisionRef"},
        "occurrence_key": {"$ref": "#/$defs/Identifier"},
        "payload": {"$ref": "#/$defs/BlobRef"},
        "occurred_at": {"$ref": "#/$defs/Timestamp"},
        "observed_at": {"$ref": "#/$defs/Timestamp"},
        "committed_at": {"$ref": "#/$defs/Timestamp"}
      }
    },
    "Run": {
      "type": "object", "additionalProperties": false,
      "required": ["schema_revision", "run_id", "origin", "runtime_policy", "budget_ledger_id", "root_task_id", "state", "state_generation", "created_at", "updated_at", "deadline_at"],
      "properties": {
        "schema_revision": {"const": 1},
        "run_id": {"$ref": "#/$defs/Identifier"},
        "occurrence": {"$ref": "#/$defs/RecordRef"},
        "origin": {"$ref": "#/$defs/RunOrigin"},
        "runtime_policy": {"$ref": "#/$defs/RevisionRef"},
        "budget_ledger_id": {"$ref": "#/$defs/Identifier"},
        "root_task_id": {"$ref": "#/$defs/Identifier"},
        "state": {"enum": ["queued", "running", "waiting", "canceling", "succeeded", "failed", "canceled", "superseded", "dead_lettered"]},
        "state_generation": {"type": "integer", "minimum": 1},
        "superseded_by": {"$ref": "#/$defs/Identifier"},
        "failure": {"$ref": "#/$defs/Failure"},
        "created_at": {"$ref": "#/$defs/Timestamp"},
        "updated_at": {"$ref": "#/$defs/Timestamp"},
        "deadline_at": {"$ref": "#/$defs/Timestamp"},
        "terminal_at": {"$ref": "#/$defs/Timestamp"}
      }
    },
    "Task": {
      "type": "object", "additionalProperties": false,
      "required": ["schema_revision", "task_id", "run_id", "depth", "objective_digest", "input_refs", "budget_ledger_id", "state", "state_generation", "created_at", "updated_at", "deadline_at"],
      "properties": {
        "schema_revision": {"const": 1},
        "task_id": {"$ref": "#/$defs/Identifier"},
        "run_id": {"$ref": "#/$defs/Identifier"},
        "parent_task_id": {"$ref": "#/$defs/Identifier"},
        "depth": {"type": "integer", "minimum": 0},
        "objective_digest": {"$ref": "#/$defs/Digest"},
        "input_refs": {"type": "array", "maxItems": 4096, "uniqueItems": true, "items": {"$ref": "#/$defs/RecordRef"}},
        "budget_ledger_id": {"$ref": "#/$defs/Identifier"},
        "session_id": {"$ref": "#/$defs/Identifier"},
        "result_artifact_id": {"$ref": "#/$defs/Identifier"},
        "state": {"enum": ["blocked", "ready", "running", "waiting", "result_committed", "succeeded", "failed", "canceled", "superseded", "dead_lettered"]},
        "state_generation": {"type": "integer", "minimum": 1},
        "failure": {"$ref": "#/$defs/Failure"},
        "created_at": {"$ref": "#/$defs/Timestamp"},
        "updated_at": {"$ref": "#/$defs/Timestamp"},
        "deadline_at": {"$ref": "#/$defs/Timestamp"},
        "terminal_at": {"$ref": "#/$defs/Timestamp"}
      }
    },
    "Dependency": {
      "type": "object", "additionalProperties": false,
      "required": ["schema_revision", "task_id", "depends_on_task_id", "requires_success", "created_at"],
      "properties": {
        "schema_revision": {"const": 1},
        "task_id": {"$ref": "#/$defs/Identifier"},
        "depends_on_task_id": {"$ref": "#/$defs/Identifier"},
        "requires_success": {"type": "boolean"},
        "created_at": {"$ref": "#/$defs/Timestamp"}
      }
    },
    "Session": {
      "type": "object", "additionalProperties": false,
      "required": ["schema_revision", "session_id", "run_id", "task_id", "generation", "execution_binding_digest", "context_manifest_digest", "state", "created_at"],
      "properties": {
        "schema_revision": {"const": 1},
        "session_id": {"$ref": "#/$defs/Identifier"},
        "run_id": {"$ref": "#/$defs/Identifier"},
        "task_id": {"$ref": "#/$defs/Identifier"},
        "generation": {"type": "integer", "minimum": 1},
        "execution_binding_digest": {"$ref": "#/$defs/Digest"},
        "context_manifest_digest": {"$ref": "#/$defs/Digest"},
        "latest_checkpoint_id": {"$ref": "#/$defs/Identifier"},
        "state": {"enum": ["open", "closed"]},
        "created_at": {"$ref": "#/$defs/Timestamp"},
        "closed_at": {"$ref": "#/$defs/Timestamp"}
      }
    },
    "Attempt": {
      "type": "object", "additionalProperties": false,
      "required": ["schema_revision", "attempt_id", "run_id", "task_id", "session_id", "ordinal", "state", "state_generation", "lease", "created_at", "updated_at"],
      "properties": {
        "schema_revision": {"const": 1},
        "attempt_id": {"$ref": "#/$defs/Identifier"},
        "run_id": {"$ref": "#/$defs/Identifier"},
        "task_id": {"$ref": "#/$defs/Identifier"},
        "session_id": {"$ref": "#/$defs/Identifier"},
        "ordinal": {"type": "integer", "minimum": 1},
        "state": {"enum": ["leased", "executing", "result_committed", "failed", "timed_out", "canceled", "superseded"]},
        "state_generation": {"type": "integer", "minimum": 1},
        "lease": {"$ref": "#/$defs/AttemptLease"},
        "result_digest": {"$ref": "#/$defs/Digest"},
        "failure": {"$ref": "#/$defs/Failure"},
        "created_at": {"$ref": "#/$defs/Timestamp"},
        "updated_at": {"$ref": "#/$defs/Timestamp"},
        "terminal_at": {"$ref": "#/$defs/Timestamp"}
      }
    },
    "Turn": {
      "type": "object", "additionalProperties": false,
      "required": ["schema_revision", "turn_id", "run_id", "task_id", "session_id", "attempt_id", "ordinal", "kind", "state", "request_digest", "created_at"],
      "properties": {
        "schema_revision": {"const": 1},
        "turn_id": {"$ref": "#/$defs/Identifier"},
        "run_id": {"$ref": "#/$defs/Identifier"},
        "task_id": {"$ref": "#/$defs/Identifier"},
        "session_id": {"$ref": "#/$defs/Identifier"},
        "attempt_id": {"$ref": "#/$defs/Identifier"},
        "ordinal": {"type": "integer", "minimum": 1},
        "kind": {"const": "model_call"},
        "state": {"enum": ["planned", "dispatched", "result_committed", "failed", "unknown", "canceled"]},
        "request_digest": {"$ref": "#/$defs/Digest"},
        "result_digest": {"$ref": "#/$defs/Digest"},
        "failure": {"$ref": "#/$defs/Failure"},
        "created_at": {"$ref": "#/$defs/Timestamp"},
        "dispatched_at": {"$ref": "#/$defs/Timestamp"},
        "finished_at": {"$ref": "#/$defs/Timestamp"}
      }
    },
    "ModelCallManifest": {
      "type": "object", "additionalProperties": false,
      "required": ["schema_revision", "call_id", "turn_id", "attempt_id", "idempotency_key", "provider", "model", "prompt_digest", "context_manifest_digest", "output_contract_digest", "request_digest", "max_output_tokens", "timeout_ms", "temperature_micros", "created_at"],
      "properties": {
        "schema_revision": {"const": 1},
        "call_id": {"$ref": "#/$defs/Identifier"},
        "turn_id": {"$ref": "#/$defs/Identifier"},
        "attempt_id": {"$ref": "#/$defs/Identifier"},
        "idempotency_key": {"$ref": "#/$defs/Identifier"},
        "provider": {"$ref": "#/$defs/Identifier"},
        "model": {"$ref": "#/$defs/Identifier"},
        "prompt_digest": {"$ref": "#/$defs/Digest"},
        "context_manifest_digest": {"$ref": "#/$defs/Digest"},
        "output_contract_digest": {"$ref": "#/$defs/Digest"},
        "request_digest": {"$ref": "#/$defs/Digest"},
        "max_output_tokens": {"type": "integer", "minimum": 1},
        "timeout_ms": {"type": "integer", "minimum": 1},
        "temperature_micros": {"type": "integer", "minimum": 0},
        "created_at": {"$ref": "#/$defs/Timestamp"}
      }
    },
    "ModelCallResult": {
      "type": "object", "additionalProperties": false,
      "required": ["schema_revision", "result_id", "call_id", "idempotency_key", "request_digest", "provider_request_id", "output", "input_tokens", "output_tokens", "finish_reason", "committed_at"],
      "properties": {
        "schema_revision": {"const": 1},
        "result_id": {"$ref": "#/$defs/Identifier"},
        "call_id": {"$ref": "#/$defs/Identifier"},
        "idempotency_key": {"$ref": "#/$defs/Identifier"},
        "request_digest": {"$ref": "#/$defs/Digest"},
        "provider_request_id": {"$ref": "#/$defs/Identifier"},
        "output": {"$ref": "#/$defs/BlobRef"},
        "input_tokens": {"type": "integer", "minimum": 0},
        "output_tokens": {"type": "integer", "minimum": 0},
        "finish_reason": {"enum": ["stop", "tool_use", "length", "content_filter"]},
        "committed_at": {"$ref": "#/$defs/Timestamp"}
      }
    },
    "Artifact": {
      "type": "object", "additionalProperties": false,
      "required": ["schema_revision", "artifact_id", "run_id", "task_id", "session_id", "attempt_id", "artifact_type", "output_contract_digest", "effect_class", "sections", "created_at"],
      "properties": {
        "schema_revision": {"const": 1},
        "artifact_id": {"$ref": "#/$defs/Identifier"},
        "run_id": {"$ref": "#/$defs/Identifier"},
        "task_id": {"$ref": "#/$defs/Identifier"},
        "session_id": {"$ref": "#/$defs/Identifier"},
        "attempt_id": {"$ref": "#/$defs/Identifier"},
        "artifact_type": {"$ref": "#/$defs/Name"},
        "output_contract_digest": {"$ref": "#/$defs/Digest"},
        "effect_class": {"const": "none"},
        "sections": {"type": "array", "minItems": 1, "maxItems": 256, "items": {"$ref": "#/$defs/ArtifactSection"}},
        "created_at": {"$ref": "#/$defs/Timestamp"}
      }
    },
    "ArtifactPublicationIntent": {
      "type": "object", "additionalProperties": false,
      "required": ["schema_revision", "intent_id", "artifact", "state", "reason_code", "created_at"],
      "properties": {
        "schema_revision": {"const": 1},
        "intent_id": {"$ref": "#/$defs/Identifier"},
        "artifact": {"$ref": "#/$defs/RecordRef"},
        "state": {"const": "disabled"},
        "reason_code": {"$ref": "#/$defs/Name"},
        "created_at": {"$ref": "#/$defs/Timestamp"}
      }
    },
    "Checkpoint": {
      "type": "object", "additionalProperties": false,
      "required": ["schema_revision", "checkpoint_id", "run_id", "task_id", "session_id", "generation", "manifest_digest", "must_preserve_refs", "created_by_attempt_id", "created_at"],
      "properties": {
        "schema_revision": {"const": 1},
        "checkpoint_id": {"$ref": "#/$defs/Identifier"},
        "run_id": {"$ref": "#/$defs/Identifier"},
        "task_id": {"$ref": "#/$defs/Identifier"},
        "session_id": {"$ref": "#/$defs/Identifier"},
        "generation": {"type": "integer", "minimum": 1},
        "previous_checkpoint_id": {"$ref": "#/$defs/Identifier"},
        "manifest_digest": {"$ref": "#/$defs/Digest"},
        "must_preserve_refs": {"type": "array", "maxItems": 4096, "uniqueItems": true, "items": {"$ref": "#/$defs/RecordRef"}},
        "narrative": {"$ref": "#/$defs/BlobRef"},
        "created_by_attempt_id": {"$ref": "#/$defs/Identifier"},
        "created_at": {"$ref": "#/$defs/Timestamp"}
      }
    },
    "BudgetLedger": {
      "type": "object", "additionalProperties": false,
      "required": ["schema_revision", "ledger_id", "scope", "scope_id", "runtime_policy", "limit", "consumed", "reserved", "generation", "state", "updated_at"],
      "properties": {
        "schema_revision": {"const": 1},
        "ledger_id": {"$ref": "#/$defs/Identifier"},
        "scope": {"enum": ["run", "task"]},
        "scope_id": {"$ref": "#/$defs/Identifier"},
        "parent_ledger_id": {"$ref": "#/$defs/Identifier"},
        "runtime_policy": {"$ref": "#/$defs/RevisionRef"},
        "limit": {"$ref": "#/$defs/BudgetLimit"},
        "consumed": {"$ref": "#/$defs/BudgetUsage"},
        "reserved": {"$ref": "#/$defs/BudgetUsage"},
        "generation": {"type": "integer", "minimum": 1},
        "state": {"enum": ["open", "exhausted", "closed"]},
        "updated_at": {"$ref": "#/$defs/Timestamp"}
      }
    },
    "CancellationRequest": {
      "type": "object", "additionalProperties": false,
      "required": ["schema_revision", "request_id", "target", "target_id", "expected_state_generation", "mode", "actor", "reason_code", "requested_at"],
      "properties": {
        "schema_revision": {"const": 1},
        "request_id": {"$ref": "#/$defs/Identifier"},
        "target": {"enum": ["run", "task"]},
        "target_id": {"$ref": "#/$defs/Identifier"},
        "expected_state_generation": {"type": "integer", "minimum": 1},
        "mode": {"enum": ["cancel", "supersede"]},
        "superseded_by_run_id": {"$ref": "#/$defs/Identifier"},
        "actor": {"$ref": "#/$defs/AuditActor"},
        "reason_code": {"$ref": "#/$defs/Name"},
        "requested_at": {"$ref": "#/$defs/Timestamp"}
      }
    },
    "RecoveryRecord": {
      "type": "object", "additionalProperties": false,
      "required": ["schema_revision", "recovery_id", "run_id", "task_id", "previous_attempt_id", "original_causation_id", "original_idempotency_key", "decision", "reason_code", "decided_at"],
      "properties": {
        "schema_revision": {"const": 1},
        "recovery_id": {"$ref": "#/$defs/Identifier"},
        "run_id": {"$ref": "#/$defs/Identifier"},
        "task_id": {"$ref": "#/$defs/Identifier"},
        "previous_attempt_id": {"$ref": "#/$defs/Identifier"},
        "original_causation_id": {"$ref": "#/$defs/Identifier"},
        "original_idempotency_key": {"$ref": "#/$defs/Identifier"},
        "decision": {"enum": ["reuse_committed_result", "retry_same_task", "dead_letter", "canceled"]},
        "committed_artifact": {"$ref": "#/$defs/RecordRef"},
        "next_attempt_id": {"$ref": "#/$defs/Identifier"},
        "reason_code": {"$ref": "#/$defs/Name"},
        "decided_at": {"$ref": "#/$defs/Timestamp"}
      }
    },
    "RuntimeEvent": {
      "type": "object", "additionalProperties": false,
      "required": ["schema_revision", "event_id", "subject", "subject_id", "to_state", "generation", "actor", "causation_id", "correlation_id", "reason_code", "occurred_at"],
      "properties": {
        "schema_revision": {"const": 1},
        "event_id": {"$ref": "#/$defs/Identifier"},
        "subject": {"enum": ["run", "task", "session", "attempt", "turn", "budget", "publication_intent"]},
        "subject_id": {"$ref": "#/$defs/Identifier"},
        "from_state": {"$ref": "#/$defs/Name"},
        "to_state": {"$ref": "#/$defs/Name"},
        "generation": {"type": "integer", "minimum": 1},
        "actor": {"$ref": "#/$defs/AuditActor"},
        "causation_id": {"$ref": "#/$defs/Identifier"},
        "correlation_id": {"$ref": "#/$defs/Identifier"},
        "reason_code": {"$ref": "#/$defs/Name"},
        "occurred_at": {"$ref": "#/$defs/Timestamp"}
      }
    },
    "ClaimTaskCommand": {
      "type": "object", "additionalProperties": false,
      "required": ["schema_revision", "envelope", "task_id", "expected_task_state_generation", "requested_lease_seconds"],
      "properties": {
        "schema_revision": {"const": 1},
        "envelope": {"$ref": "#/$defs/CommandEnvelope"},
        "task_id": {"$ref": "#/$defs/Identifier"},
        "expected_task_state_generation": {"type": "integer", "minimum": 1},
        "requested_lease_seconds": {"type": "integer", "minimum": 1}
      }
    },
    "HeartbeatAttemptCommand": {
      "type": "object", "additionalProperties": false,
      "required": ["schema_revision", "envelope", "attempt_id", "expected_attempt_state_generation", "lease_generation", "lease_token", "requested_extension_seconds"],
      "properties": {
        "schema_revision": {"const": 1},
