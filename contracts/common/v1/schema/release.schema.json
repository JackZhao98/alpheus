{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://alpheus.local/contracts/common/v1/schema/release.schema.json",
  "title": "Alpheus Agent Platform Release Manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_revision", "canonical_profile", "release_id", "stage", "decision", "source_commit", "created_at", "authorized_by", "effect_ceiling", "documents", "checks"],
  "properties": {
    "schema_revision": {"const": 1},
    "canonical_profile": {"const": "alpheus-c14n-v1"},
    "release_id": {"$ref": "common.schema.json#/$defs/OpaqueID"},
    "stage": {"enum": ["AP0", "AP1", "AP2", "AP3", "AP4", "AP5", "AP6", "AP7", "AP8", "AP9", "AP10", "AP11", "AP12", "AP13", "AP14", "AP15"]},
    "decision": {"enum": ["authorized", "rejected"]},
    "source_commit": {"type": "string", "pattern": "^([0-9a-f]{40}|[0-9a-f]{64})$"},
    "created_at": {"$ref": "common.schema.json#/$defs/UTCInstant"},
    "authorized_by": {
      "allOf": [
        {"$ref": "common.schema.json#/$defs/AuditActor"},
        {"properties": {"kind": {"const": "user"}, "audience": {"const": "activator"}}}
      ]
    },
    "effect_ceiling": {"$ref": "common.schema.json#/$defs/EffectClass"},
    "documents": {
      "type": "array",
      "minItems": 1,
      "maxItems": 256,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "digest"],
        "properties": {
          "path": {"type": "string", "minLength": 1, "maxLength": 300},
          "digest": {"$ref": "common.schema.json#/$defs/Digest"}
        }
      }
    },
    "checks": {
      "type": "array",
      "minItems": 1,
      "maxItems": 256,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "status", "evidence_digest"],
        "properties": {
          "name": {"type": "string", "pattern": "^[a-z][a-z0-9_.-]{0,79}$"},
          "status": {"enum": ["fail", "pass"]},
          "evidence_digest": {"$ref": "common.schema.json#/$defs/Digest"}
        }
      }
    }
  },
  "allOf": [
    {
      "if": {"properties": {"stage": {"const": "AP0"}}, "required": ["stage"]},
      "then": {"properties": {"effect_ceiling": {"const": "none"}}}
    }
  ]
}
