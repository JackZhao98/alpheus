FROM golang:1.23-alpine AS build
WORKDIR /src
COPY agent-platform/go.mod agent-platform/go.sum ./
RUN go mod download
COPY agent-platform/ ./
RUN CGO_ENABLED=0 go build -trimpath -o /bin/cortex-worker ./cmd/cortex-worker

FROM alpine:3.20
RUN apk add --no-cache ca-certificates su-exec \
    && addgroup -S cortex && adduser -S -G cortex cortex
COPY --from=build /bin/cortex-worker /usr/local/bin/cortex-worker
COPY agent-platform/cortex-worker-entrypoint.sh /usr/local/bin/cortex-worker-entrypoint
ENTRYPOINT ["/usr/local/bin/cortex-worker-entrypoint"]
