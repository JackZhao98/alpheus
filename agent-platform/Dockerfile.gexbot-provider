FROM golang:1.23-alpine AS build
WORKDIR /src
COPY agent-platform/go.mod agent-platform/go.sum ./
RUN go mod download
COPY agent-platform/ ./
RUN CGO_ENABLED=0 go build -trimpath -o /bin/gexbot-provider ./cmd/gexbot-provider

FROM alpine:3.20
RUN apk add --no-cache ca-certificates
COPY --from=build /bin/gexbot-provider /usr/local/bin/gexbot-provider
EXPOSE 8500
ENTRYPOINT ["/usr/local/bin/gexbot-provider"]
